@page
@model AvatarModel
@{
    ViewData["Title"] = "Medical Instructor Avatar";
    ViewData["PageClass"] = "page-avatar";
}

<link rel="stylesheet" href="~/css/custom.css" />
<style>
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
    .fa-circle[style*="animation"] {
        display: inline-block;
    }
</style>

<div class="avatar-experience">
    <div class="avatar-stage">
        <video id="avatarVideo" autoplay playsinline muted hidden></video>
        <audio id="avatarAudio" autoplay volume="1.0"></audio>

        <div id="placeholder" class="avatar-placeholder">
            <div class="avatar-placeholder__icon">
                <i class="fas fa-user-md"></i>
            </div>
            <p class="avatar-placeholder__eyebrow">HeyGen AI stream</p>
            <h2>Dr. Dexter is standing by</h2>
            <p>Start a session to begin a live ER coaching consult.</p>
        </div>

        <div id="loading" class="avatar-loading" hidden>
            <div class="spinner-border text-light mb-3" role="status"></div>
            <p id="loadingText">Connecting...</p>
        </div>
    </div>

    <div class="video-header">
        <div class="video-header__content">
            <div class="video-header__title">
                <h3>Dr. Dexter</h3>
                <span class="video-header__status" id="callStatus">Ready</span>
            </div>
            <div class="video-header__timer" id="callTimer">00:00</div>
        </div>
        <div class="pip-view" id="pipView" hidden>
            <div class="pip-view__badge">Patient</div>
            <div class="pip-view__avatar">
                <i class="fas fa-user"></i>
            </div>
            <div class="pip-view__meta">
                <span class="pip-view__name">Patient Cam</span>
                <span class="pip-view__status">Live</span>
            </div>
        </div>
    </div>

    <div class="floating-controls">
        <button class="control-btn control-btn--mute" id="muteBtn" disabled>
            <i class="fas fa-microphone"></i>
        </button>
        <button class="control-btn control-btn--chat" id="chatToggleBtn">
            <i class="fas fa-comments"></i>
        </button>
        <button class="control-btn control-btn--end" id="endCallBtn" disabled>
            <i class="fas fa-phone-slash"></i>
        </button>
    </div>

    <div class="session-panel" id="sessionPanel">
        <div class="session-panel__actions">
            <label class="session-action session-action--toggle" for="useClaudeToggle">
                <span class="session-action__icon"><i class="fas fa-brain"></i></span>
                <span class="session-action__label">Claude</span>
                <input type="checkbox" id="useClaudeToggle" class="form-check-input" title="Use Claude instead of local Ollama (same RAG PDFs)">
            </label>
        </div>

        <button class="session-toggle-button session-toggle-button--start" type="button" id="startButton">
            <i class="fas fa-play me-2"></i>Start Session
        </button>
        <button class="session-toggle-button session-toggle-button--stop" type="button" id="stopButton" hidden>
            <i class="fas fa-stop me-2"></i>Stop Session
        </button>

        <div id="recordingStatus" class="recording-status" hidden>
            <small>
                <i class="fas fa-circle me-1" style="animation: pulse 1s infinite;"></i>
                Recording... Click again to stop and send
            </small>
        </div>
    </div>

    <div class="chat-drawer" id="chatDrawer">
        <div class="chat-drawer__header">
            <h4>Session Chat</h4>
            <button class="chat-drawer__close" id="closeChatBtn">
                <i class="fas fa-chevron-down"></i>
            </button>
        </div>
        
        <div class="chat-messages chat-transcript consultation-transcript" id="chatHistory">
            <div class="transcript-placeholder">
                <i class="fas fa-comments"></i>
                <p>Conversation transcript will appear here</p>
            </div>
        </div>

        <div class="drawer-footer">
            <div class="drawer-composer">
                <input type="text" id="messageInput" class="form-control consultation-input" placeholder="Ask your medical question..." maxlength="500" disabled>
                <button class="session-action session-action--primary" type="button" id="sendButton" disabled>
                    <span class="session-action__icon"><i class="fas fa-paper-plane"></i></span>
                    <span class="session-action__label">Send</span>
                </button>
            </div>
        </div>
    </div>
</div>
<div style="display:none;">
    <div class="logs-panel sources-panel h-100 d-flex flex-column">
        <div class="sources-header">
            <h5 class="mb-0">
                <i class="fas fa-link me-2"></i>
                Reference Sources
            </h5>
            <p class="text-white-50 small mb-0">Medical documents referenced in the avatar's response.</p>
        </div>
        <div class="sources-body" id="sourcesContainer">
            <div class="text-center text-muted py-5">
                <i class="fas fa-graduation-cap fa-3x mb-3" style="color: #94a3b8;"></i>
                <p>No sources yet</p>
                <p class="small">Start a conversation to see cited references.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>
<script>
(function() {
    'use strict';

    const API_BASE = '/api/avatar/v2/streaming';
    const KEEPALIVE_INTERVAL_MS = 45000;
    let liveKitRoom = null;
    let sessionData = null;
    let streamingToken = null;
    let isSessionActive = false;
    let keepaliveIntervalId = null;
    let callStartTime = null;
    let callTimerInterval = null;
    let isChatDrawerOpen = false;
    let mediaRecorder = null;
    let audioChunks = [];
    let isRecording = false;
    let audioStream = null;
    let speechRecognition = null;
    let speechTranscript = '';
    let shouldSubmitSpeechTranscript = false;
    let speechSilenceTimer = null;
    const SPEECH_SILENCE_MS = 1500;

    const elements = {
        video: document.getElementById('avatarVideo'),
        audio: document.getElementById('avatarAudio'),
        placeholder: document.getElementById('placeholder'),
        loading: document.getElementById('loading'),
        loadingText: document.getElementById('loadingText'),
        chatHistory: document.getElementById('chatHistory'),
        messageInput: document.getElementById('messageInput'),
        sendButton: document.getElementById('sendButton'),
        startButton: document.getElementById('startButton'),
        stopButton: document.getElementById('stopButton'),
        callStatus: document.getElementById('callStatus'),
        callTimer: document.getElementById('callTimer'),
        sourcesContainer: document.getElementById('sourcesContainer'),
        recordingStatus: document.getElementById('recordingStatus'),
        chatToggleBtn: document.getElementById('chatToggleBtn'),
        closeChatBtn: document.getElementById('closeChatBtn'),
        chatDrawer: document.getElementById('chatDrawer'),
        muteBtn: document.getElementById('muteBtn'),
        endCallBtn: document.getElementById('endCallBtn'),
        pipView: document.getElementById('pipView')
    };

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function updateStatus(text, type = 'secondary') {
        if (elements.callStatus) {
            elements.callStatus.textContent = text;
            elements.callStatus.className = `video-header__status video-header__status--${type}`;
        }
    }

    function startCallTimer() {
        callStartTime = new Date();
        callTimerInterval = setInterval(() => {
            if (!callStartTime) return;
            const elapsed = Math.floor((new Date() - callStartTime) / 1000);
            const minutes = Math.floor(elapsed / 60).toString().padStart(2, '0');
            const seconds = (elapsed % 60).toString().padStart(2, '0');
            if (elements.callTimer) {
                elements.callTimer.textContent = `${minutes}:${seconds}`;
            }
        }, 1000);
    }

    function stopCallTimer() {
        if (callTimerInterval) {
            clearInterval(callTimerInterval);
            callTimerInterval = null;
        }
        callStartTime = null;
        if (elements.callTimer) {
            elements.callTimer.textContent = '00:00';
        }
    }

    function toggleChatDrawer() {
        isChatDrawerOpen = !isChatDrawerOpen;
        if (elements.chatDrawer) {
            elements.chatDrawer.classList.toggle('chat-drawer--open', isChatDrawerOpen);
        }
        if (elements.chatToggleBtn) {
            elements.chatToggleBtn.classList.toggle('control-btn--active', isChatDrawerOpen);
        }
    }

    function closeChatDrawer() {
        isChatDrawerOpen = false;
        if (elements.chatDrawer) {
            elements.chatDrawer.classList.remove('chat-drawer--open');
        }
        if (elements.chatToggleBtn) {
            elements.chatToggleBtn.classList.remove('control-btn--active');
        }
    }

    function showLoading(text = 'Loading...') {
        elements.loadingText.textContent = text;
        elements.loading.hidden = false;
        elements.placeholder.hidden = true;
    }

    function hideLoading() {
        elements.loading.hidden = true;
    }

    function clearSpeechSilenceTimer() {
        if (speechSilenceTimer) {
            clearTimeout(speechSilenceTimer);
            speechSilenceTimer = null;
        }
    }

    function scheduleSpeechAutoStop() {
        clearSpeechSilenceTimer();
        speechSilenceTimer = setTimeout(() => {
            if (speechRecognition && isRecording) {
                console.log('[SPEECH] Silence detected, auto-stopping recognition');
                speechRecognition.stop();
            }
        }, SPEECH_SILENCE_MS);
    }

    function getSpeechRecognitionCtor() {
        return window.SpeechRecognition || window.webkitSpeechRecognition || null;
    }

    function resetVoiceButton(disabled = !isSessionActive) {
        elements.muteBtn.innerHTML = '<i class="fas fa-microphone"></i>';
        elements.muteBtn.classList.remove('control-btn--muted');
        elements.muteBtn.classList.remove('control-btn--active');
        elements.muteBtn.disabled = disabled;
        elements.recordingStatus.hidden = true;
    }

    function setVoiceButtonRecordingState() {
        elements.muteBtn.innerHTML = '<i class="fas fa-stop"></i>';
        elements.muteBtn.classList.add('control-btn--active');
        elements.muteBtn.classList.add('control-btn--muted');
        elements.muteBtn.disabled = false;
        elements.recordingStatus.hidden = false;
    }

    function addMessage(sender, message, isError = false) {
        // Remove placeholder
        const placeholder = elements.chatHistory.querySelector('.transcript-placeholder');
        if (placeholder) placeholder.remove();

        const messageDiv = document.createElement('div');
        const escapedMessage = escapeHtml(message).replace(/\n/g, '<br>');
        const bubbleType = isError
            ? 'chat-bubble-entry--error'
            : sender === 'User'
                ? 'chat-bubble-entry--user'
                : sender === 'System'
                    ? 'chat-bubble-entry--system'
                    : 'chat-bubble-entry--assistant';

        messageDiv.className = `chat-bubble-entry ${bubbleType}`;
        
        messageDiv.innerHTML = `
            <span class="chat-bubble-entry__sender">${escapeHtml(sender)}</span>
            <div class="chat-bubble-entry__body">${escapedMessage}</div>
            <small class="chat-bubble-entry__time">${new Date().toLocaleTimeString()}</small>
        `;

        elements.chatHistory.appendChild(messageDiv);
        elements.chatHistory.scrollTop = elements.chatHistory.scrollHeight;
    }

    function updateSources(sources, isFallback) {
        elements.sourcesContainer.innerHTML = '';

        if (isFallback) {
            elements.sourcesContainer.innerHTML = `
                <div class="text-center text-muted py-5">
                    <i class="fas fa-plug-circle-exclamation fa-3x mb-3" style="color: #ea580c;"></i>
                    <p>Reference services are offline.</p>
                </div>
            `;
            return;
        }

        if (!sources || sources.length === 0) {
            elements.sourcesContainer.innerHTML = `
                <div class="text-center text-muted py-5">
                    <i class="fas fa-graduation-cap fa-3x mb-3" style="color: #94a3b8;"></i>
                    <p>No sources yet</p>
                </div>
            `;
            return;
        }

        sources.forEach(source => {
            if (!source || !source.url) return;

            const entry = document.createElement('div');
            entry.className = 'source-entry mb-3 p-3 bg-dark rounded';
            
            const titleLink = document.createElement('a');
            titleLink.className = 'text-white text-decoration-none';
            titleLink.href = source.url;
            titleLink.target = '_blank';
            titleLink.textContent = source.title || 'Reference material';
            titleLink.style.fontWeight = 'bold';

            entry.appendChild(titleLink);

            if (source.preview) {
                const preview = document.createElement('p');
                preview.className = 'text-white-50 small mt-2 mb-0';
                preview.textContent = source.preview;
                entry.appendChild(preview);
            }

            elements.sourcesContainer.appendChild(entry);
        });
    }

    function unlockAudioForMobile() {
        try {
            var el = document.getElementById('avatarAudio');
            if (!el) return;
            var silentWav = 'data:audio/wav;base64,UklGRiQAAABXQVZFZm10IBAAAAABAAEARKwAAIhYAQACABAAZGF0YQAAAAA=';
            el.src = silentWav;
            el.volume = 0;
            el.play().then(function() { el.src = ''; }).catch(function() { el.src = ''; });
        } catch (e) { /* ignore */ }
    }

    async function connectToLiveKit(url, accessToken) {
        return new Promise((resolve, reject) => {
            let attempts = 0;
            const maxAttempts = 20;
            
            function checkLiveKit() {
                const LiveKit = window.LivekitClient;
                if (LiveKit) {
                    try {
                        const room = new LiveKit.Room({
                            adaptiveStream: true,
                            dynacast: true
                        });

                        let videoTrackReceived = false;
                        let audioTrackReceived = false;

                        room.on(LiveKit.RoomEvent.TrackSubscribed, (track, publication, participant) => {
                            console.log('[LK] TrackSubscribed:', track.kind, {
                                participant: participant?.identity || 'unknown',
                                sid: track.sid,
                                trackId: track.trackId,
                                isMuted: track.isMuted,
                                isSubscribed: track.isSubscribed
                            });
                            
                            if (track.kind === LiveKit.Track.Kind.Video || track.kind === 'video') {
                                track.attach(elements.video);
                                elements.video.muted = true;
                                elements.video.playsInline = true;
                                elements.video.autoplay = true;
                                elements.video.hidden = false;
                                elements.placeholder.hidden = true;
                                videoTrackReceived = true;
                                
                                const playPromise = elements.video.play();
                                if (playPromise !== undefined) {
                                    playPromise
                                        .then(() => {
                                            console.log('[LK] Video play() succeeded');
                                        })
                                        .catch((err) => {
                                            console.error('[LK] Video play error:', err);
                                        });
                                }
                                
                                if (audioTrackReceived) {
                                    hideLoading();
                                    updateStatus('Connected', 'success');
                                } else {
                                    updateStatus('Connecting audio...', 'warning');
                                }
                                
                            } else if (track.kind === LiveKit.Track.Kind.Audio || track.kind === 'audio') {
                                console.log('[LK] Audio track subscribed, attaching to element');
                                elements.audio.src = '';
                                track.attach(elements.audio);
                                elements.audio.autoplay = true;
                                elements.audio.muted = false;
                                elements.audio.volume = 1.0;
                                audioTrackReceived = true;
                                
                                const playPromise = elements.audio.play();
                                if (playPromise !== undefined) {
                                    playPromise
                                        .then(() => {
                                            console.log('[LK] Audio playback started successfully');
                                            if (videoTrackReceived) {
                                                hideLoading();
                                                updateStatus('Connected', 'success');
                                            }
                                        })
                                        .catch((error) => {
                                            console.warn('[LK] Audio play was prevented:', error);
                                        });
                                }
                                
                                if (videoTrackReceived) {
                                    hideLoading();
                                    updateStatus('Connected', 'success');
                                }
                            }
                        });

                        room.on(LiveKit.RoomEvent.TrackUnsubscribed, (track, publication, participant) => {
                            console.log(`Track unsubscribed: ${track.kind} from ${participant?.identity || 'unknown'}`);
                            if (track.kind === 'video') {
                                track.detach(elements.video);
                            } else if (track.kind === 'audio') {
                                track.detach(elements.audio);
                            }
                            if (track.kind === 'video') {
                                videoTrackReceived = false;
                                elements.video.hidden = true;
                                elements.placeholder.hidden = false;
                                updateStatus('Video disconnected', 'warning');
                            } else if (track.kind === 'audio') {
                                audioTrackReceived = false;
                                if (videoTrackReceived) {
                                    updateStatus('Audio disconnected', 'warning');
                                }
                            }
                        });

                        room.on(LiveKit.RoomEvent.Disconnected, () => {
                            console.log('Room disconnected');
                            stopKeepalive();
                            updateStatus('Disconnected', 'danger');
                            shouldSubmitSpeechTranscript = false;
                            isSessionActive = false;
                            document.body.classList.remove('session-active');
                            sessionData = null;
                            liveKitRoom = null;
                            streamingToken = null;
                            elements.messageInput.disabled = true;
                            elements.sendButton.disabled = true;
                            elements.startButton.hidden = false;
                            elements.startButton.disabled = false;
                            elements.stopButton.hidden = true;
                            elements.stopButton.disabled = false;
                            elements.video.hidden = true;
                            elements.placeholder.hidden = false;
                            if (elements.pipView) {
                                elements.pipView.hidden = true;
                            }
                            resetVoiceButton(true);
                            hideLoading();
                            addMessage('System', 'Connection lost. Click "Start Session" to reconnect.', false);
                        });

                        const connectPromise = room.connect(url, accessToken);
                        const timeoutPromise = new Promise((_, rejectTimeout) => 
                            setTimeout(() => rejectTimeout(new Error('Connection timeout after 30 seconds')), 30000)
                        );

                        Promise.race([connectPromise, timeoutPromise])
                            .then(() => {
                                console.log('LiveKit connected successfully');
                                resolve(room);
                            })
                            .catch(reject);
                    } catch (error) {
                        reject(error);
                    }
                } else if (attempts < maxAttempts) {
                    attempts++;
                    setTimeout(checkLiveKit, 500);
                } else {
                    reject(new Error('LiveKit client library failed to load'));
                }
            }

            checkLiveKit();
        });
    }

    async function createSession() {
        console.log('[API] Calling POST', `${API_BASE}/session/create`);
        const response = await fetch(`${API_BASE}/session/create`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        console.log('[API] session/create response status:', response.status, response.statusText);

        if (!response.ok) {
            const error = await response.json();
            console.error('[API] session/create error:', error);
            throw new Error(error.message || `HTTP ${response.status}`);
        }

        const data = await response.json();
        console.log('[API] session/create success:', { 
            sessionId: data.sessionId?.substring(0, 8) + '...', 
            hasStreamingToken: !!data.streamingToken,
            hasUrl: !!data.url,
            hasAccessToken: !!data.accessToken
        });
        return data;
    }

    async function sendTask(sessionId, message) {
        if (!streamingToken) {
            console.error('[API] CRITICAL: streamingToken is missing! Cannot send task.');
            throw new Error('Streaming token is required. Please restart the session.');
        }

        const useClaude = document.getElementById('useClaudeToggle')?.checked === true;
        const payload = {
            message: message,
            conversationId: sessionId,
            streamingToken: streamingToken,
            useClaude: useClaude
        };

        console.log('[API] Calling POST', `${API_BASE}/task`, {
            conversationId: sessionId,
            messageLength: message.length,
            hasStreamingToken: !!streamingToken,
            streamingTokenLength: streamingToken.length
        });

        const response = await fetch(`${API_BASE}/task`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        console.log('[API] /task response status:', response.status, response.statusText);

        if (!response.ok) {
            let errorMessage = `HTTP ${response.status}`;
            try {
                const errorData = await response.json();
                console.error('[API] /task error response:', errorData);
                errorMessage = errorData.error || errorData.message || errorMessage;
            } catch (e) {
                // If response isn't JSON, try to get text
                try {
                    const errorText = await response.text();
                    console.error('[API] /task error text:', errorText);
                    errorMessage = errorText || errorMessage;
                } catch (e2) {
                    // Use default error message
                }
            }
            throw new Error(errorMessage);
        }

        const data = await response.json();
        console.log('[API] /task success:', { 
            hasTranscript: !!data.transcript,
            transcriptLength: data.transcript?.length || 0,
            sourceCount: data.sources?.length || 0
        });
        return data;
    }

    async function stopSession(sessionId) {
        try {
            await fetch(`${API_BASE}/session/stop`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    sessionId: sessionId,
                    streamingToken: streamingToken
                })
            });
        } catch (error) {
            console.error('Error stopping session:', error);
        }
    }

    async function sendKeepalive() {
        if (!sessionData?.sessionId || !streamingToken || !isSessionActive) return;
        try {
            const res = await fetch(`${API_BASE}/session/keepalive`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sessionId: sessionData.sessionId, streamingToken: streamingToken })
            });
            const data = await res.json();
            if (!data.success) console.warn('[KEEPALIVE] Session may have closed:', data.error);
        } catch (e) {
            console.warn('[KEEPALIVE] Request failed:', e.message);
        }
    }

    function startKeepalive() {
        stopKeepalive();
        keepaliveIntervalId = setInterval(sendKeepalive, KEEPALIVE_INTERVAL_MS);
    }

    function stopKeepalive() {
        if (keepaliveIntervalId) {
            clearInterval(keepaliveIntervalId);
            keepaliveIntervalId = null;
        }
    }

    async function startSession() {
        console.log('[SESSION] startSession() called');
        unlockAudioForMobile();
        try {
            elements.startButton.disabled = true;
            showLoading('Creating session...');
            updateStatus('Creating session...', 'warning');

            console.log('[SESSION] Step 1: Creating session via API...');
            const sessionResponse = await createSession();
            console.log('[SESSION] Session created successfully:', {
                sessionId: sessionResponse.sessionId?.substring(0, 8) + '...',
                hasStreamingToken: !!sessionResponse.streamingToken
            });
            sessionData = sessionResponse;
            streamingToken = sessionResponse.streamingToken;

            showLoading('Connecting to avatar...');
            updateStatus('Connecting...', 'warning');

            liveKitRoom = await connectToLiveKit(sessionResponse.url, sessionResponse.accessToken);

            try {
                console.log('Sending initial greeting to animate avatar...');
                const greeting = "Briefly introduce yourself as Dr. Dexter, an experienced ER physician. Mention you have access to a medical knowledge database and ask what topic they'd like to learn about.";
                const greetingResponse = await sendTask(sessionResponse.sessionId, greeting);
                
                console.log('Greeting sent successfully, avatar should now be animating');
                
                if (greetingResponse.transcript) {
                    addMessage('Avatar', greetingResponse.transcript);
                }
                if (greetingResponse.sources) {
                    updateSources(greetingResponse.sources, greetingResponse.isFallback);
                }
            } catch (error) {
                console.error('Error sending greeting:', error);
                addMessage('System', `Note: Initial greeting failed (${error.message}). The avatar may appear static until you send a message.`, false);
            }

            isSessionActive = true;
            document.body.classList.add('session-active');
            elements.messageInput.disabled = false;
            elements.sendButton.disabled = false;
            resetVoiceButton(false);
            elements.muteBtn.disabled = false;
            elements.endCallBtn.disabled = false;
            elements.startButton.hidden = true;
            elements.stopButton.hidden = false;
            if (elements.pipView) {
                elements.pipView.hidden = false;
            }
            updateStatus('Connected', 'success');
            startKeepalive();
            startCallTimer();

        } catch (error) {
            console.error('Error starting session:', error);
            addMessage('System', `Failed to start session: ${error.message}`, true);
            updateStatus('Error', 'danger');
            hideLoading();
            elements.placeholder.hidden = false;
            if (elements.pipView) {
                elements.pipView.hidden = true;
            }
            resetVoiceButton(true);
            elements.startButton.disabled = false;
            document.body.classList.remove('session-active');

            if (sessionData) {
                await stopSession(sessionData.sessionId);
            }
            if (liveKitRoom) {
                try {
                    liveKitRoom.disconnect();
                } catch (e) {
                    console.error('Error disconnecting:', e);
                }
            }
            
            sessionData = null;
            streamingToken = null;
        }
    }

    async function stopSessionHandler() {
        try {
            elements.stopButton.disabled = true;
            updateStatus('Stopping...', 'warning');
            stopKeepalive();
            stopCallTimer();
            shouldSubmitSpeechTranscript = false;

            if (sessionData) {
                await stopSession(sessionData.sessionId);
            }

            if (liveKitRoom) {
                liveKitRoom.disconnect();
            }

            isSessionActive = false;
            document.body.classList.remove('session-active');
            sessionData = null;
            liveKitRoom = null;

            elements.video.hidden = true;
            elements.placeholder.hidden = false;
            if (elements.pipView) {
                elements.pipView.hidden = true;
            }
            hideLoading();
            elements.messageInput.disabled = true;
            elements.sendButton.disabled = true;
            resetVoiceButton(true);
            elements.muteBtn.disabled = true;
            elements.endCallBtn.disabled = true;
            elements.startButton.hidden = false;
            elements.stopButton.hidden = true;
            elements.startButton.disabled = false;
            updateStatus('Ready', 'secondary');
            sessionData = null;
            streamingToken = null;
            addMessage('System', 'Session stopped.', false);
            
            if (isRecording) {
                stopRecording();
            }
            if (audioStream) {
                audioStream.getTracks().forEach(track => track.stop());
                audioStream = null;
            }

        } catch (error) {
            console.error('Error stopping session:', error);
            addMessage('System', `Error stopping session: ${error.message}`, true);
            elements.stopButton.disabled = false;
        }
    }

    async function sendMessage() {
        console.log('[MESSAGE] sendMessage() called');
        const message = elements.messageInput.value.trim();
        if (!message || !isSessionActive) {
            console.warn('[MESSAGE] Cannot send - message empty or session not active', { message: !!message, isSessionActive });
            return;
        }

        if (!sessionData || !sessionData.sessionId) {
            console.error('[MESSAGE] CRITICAL: sessionData is missing!');
            addMessage('System', 'Session not initialized. Please start a session first.', true);
            return;
        }

        if (!streamingToken) {
            console.error('[MESSAGE] CRITICAL: streamingToken is missing!');
            addMessage('System', 'Streaming token missing. Please restart the session.', true);
            return;
        }

        console.log('[MESSAGE] Sending message via API:', {
            sessionId: sessionData.sessionId,
            messageLength: message.length,
            hasStreamingToken: !!streamingToken
        });

        addMessage('User', message);
        elements.messageInput.value = '';
        elements.sendButton.disabled = true;
        showLoading('Processing...');
        updateStatus('Processing...', 'warning');

        try {
            const response = await sendTask(sessionData.sessionId, message);
            
            if (response.transcript) {
                addMessage('Avatar', response.transcript);
            }
            if (response.sessionExpired && liveKitRoom) {
                try { liveKitRoom.disconnect(); } catch (e) { console.warn('Disconnect on session expired:', e); }
                liveKitRoom = null;
                addMessage('System', 'Session expired (response took too long or you reconnected). Click "Start Session" to continue.', false);
            } else if (response.avatarDeliveryFailed) {
                addMessage('System', 'Response is shown above; avatar couldn\'t speak this time. Click "Start Session" if you need to reconnect.', false);
            }
            if (response.sources) {
                updateSources(response.sources, response.isFallback);
            }

            hideLoading();
            updateStatus(response.sessionExpired ? 'Disconnected' : 'Connected', response.sessionExpired ? 'danger' : 'success');
        } catch (error) {
            console.error('Error sending message:', error);
            addMessage('System', `Error: ${error.message}`, true);
            hideLoading();
            updateStatus('Error', 'danger');
        } finally {
            elements.sendButton.disabled = false;
        }
    }

    function getSupportedMimeType() {
        const types = [
            'audio/webm;codecs=opus',
            'audio/webm',
            'audio/ogg;codecs=opus',
            'audio/ogg',
            'audio/mp4',
            'audio/mpeg'
        ];
        
        for (const type of types) {
            if (MediaRecorder.isTypeSupported(type)) {
                console.log('[RECORD] Using mimeType:', type);
                return type;
            }
        }
        
        console.warn('[RECORD] No preferred mimeType found, using browser default');
        return '';
    }

    async function startMediaRecorderCapture(showFallbackNotice = false) {
        try {
            if (showFallbackNotice) {
                addMessage('System', 'Built-in voice recognition failed, switching to microphone transcription.', false);
            }

            console.log('[RECORD] ===== USING ELEVENLABS FOR SPEECH-TO-TEXT =====');
            if (!navigator.mediaDevices || typeof navigator.mediaDevices.getUserMedia !== 'function') {
                const isSecure = window.location.protocol === 'https:' || window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
                throw new Error(isSecure
                    ? 'Microphone API is not available in this browser.'
                    : 'Voice input requires HTTPS. Open this app at https://149.165.168.99:8443 instead (run the app with ServerHttps profile, then accept the browser security warning once).');
            }
            if (!window.MediaRecorder) {
                throw new Error('Audio recording is not supported in this browser. Please use Chrome, Edge, or Firefox.');
            }

            console.log('[RECORD] Requesting microphone access for speech-to-text...');
            audioStream = await navigator.mediaDevices.getUserMedia({
                audio: {
                    channelCount: 1,
                    sampleRate: 16000,
                    echoCancellation: true,
                    noiseSuppression: true
                }
            });
            console.log('[RECORD] Microphone access granted');

            const mimeType = getSupportedMimeType();
            const options = mimeType ? { mimeType: mimeType } : {};

            try {
                mediaRecorder = new MediaRecorder(audioStream, options);
                console.log('[RECORD] MediaRecorder created with options:', options);
            } catch (recorderError) {
                console.error('[RECORD] Failed to create MediaRecorder with options:', options, recorderError);
                mediaRecorder = new MediaRecorder(audioStream);
                console.log('[RECORD] MediaRecorder created with browser default');
            }

            const actualMimeType = mediaRecorder.mimeType || 'audio/webm';
            console.log('[RECORD] Actual MediaRecorder mimeType:', actualMimeType);

            audioChunks = [];

            mediaRecorder.ondataavailable = (event) => {
                if (event.data && event.data.size > 0) {
                    console.log('[RECORD] Data chunk received:', event.data.size, 'bytes');
                    audioChunks.push(event.data);
                }
            };

            mediaRecorder.onerror = (event) => {
                console.error('[RECORD] MediaRecorder error:', event.error);
                addMessage('System', `Recording error: ${event.error?.message || 'Unknown error'}`, true);
                stopRecording();
            };

            mediaRecorder.onstop = async () => {
                console.log('[RECORD] Recording stopped, chunks:', audioChunks.length);

                if (audioChunks.length === 0) {
                    console.error('[RECORD] No audio chunks recorded!');
                    addMessage('System', 'No audio was recorded. Please try again.', true);
                    resetVoiceButton(false);
                    return;
                }

                const audioBlob = new Blob(audioChunks, { type: actualMimeType });
                console.log('[RECORD] Audio blob created:', {
                    size: audioBlob.size,
                    type: audioBlob.type
                });

                if (audioStream) {
                    audioStream.getTracks().forEach(track => {
                        track.stop();
                        console.log('[RECORD] Audio track stopped');
                    });
                    audioStream = null;
                }

                await sendAudio(audioBlob);
            };

            mediaRecorder.start(100);
            isRecording = true;
            console.log('[RECORD] Recording started');

            setVoiceButtonRecordingState();
            updateStatus('Recording...', 'warning');
        } catch (error) {
            console.error('[RECORD] Error starting recording:', error);

            let errorMessage = error.message;
            if (error.name === 'NotAllowedError') {
                errorMessage = 'Microphone access denied. Please allow microphone access and try again.';
            } else if (error.name === 'NotFoundError') {
                errorMessage = 'No microphone found. Please connect a microphone and try again.';
            } else if (error.name === 'NotSupportedError') {
                errorMessage = 'Audio recording is not supported in this browser.';
            }

            addMessage('System', `Error accessing microphone: ${errorMessage}`, true);
            isRecording = false;
            resetVoiceButton(false);

            if (audioStream) {
                audioStream.getTracks().forEach(track => track.stop());
                audioStream = null;
            }
        }
    }

    async function startBrowserSpeechRecognition() {
        const SpeechRecognitionCtor = getSpeechRecognitionCtor();
        if (!SpeechRecognitionCtor) {
            return false;
        }

        speechTranscript = '';
        shouldSubmitSpeechTranscript = true;
        speechRecognition = new SpeechRecognitionCtor();
        speechRecognition.lang = navigator.language || 'en-US';
        speechRecognition.continuous = true;
        speechRecognition.interimResults = true;
        speechRecognition.maxAlternatives = 1;

        speechRecognition.onresult = (event) => {
            let finalChunk = '';
            let interimChunk = '';

            for (let i = event.resultIndex; i < event.results.length; i++) {
                const transcriptPart = event.results[i][0]?.transcript || '';
                if (event.results[i].isFinal) {
                    finalChunk += transcriptPart;
                } else {
                    interimChunk += transcriptPart;
                }
            }

            if (finalChunk) {
                speechTranscript = `${speechTranscript} ${finalChunk}`.trim();
            }

            elements.messageInput.value = `${speechTranscript} ${interimChunk}`.trim();

            const combinedTranscript = `${speechTranscript} ${interimChunk}`.trim();
            if (combinedTranscript) {
                scheduleSpeechAutoStop();
            }
        };

        speechRecognition.onerror = (event) => {
            console.error('[SPEECH] Speech recognition error:', event.error);
            clearSpeechSilenceTimer();
            shouldSubmitSpeechTranscript = false;
            isRecording = false;
            speechRecognition = null;
            resetVoiceButton(false);

            if (event.error === 'not-allowed' || event.error === 'service-not-allowed') {
                addMessage('System', 'Microphone access was denied. Please allow microphone access and try again.', true);
                return;
            }

            if (event.error === 'no-speech') {
                addMessage('System', 'No speech was detected. Please try again and speak clearly into your microphone.', true);
                return;
            }

            void startMediaRecorderCapture(true);
        };

        speechRecognition.onend = async () => {
            clearSpeechSilenceTimer();
            const transcriptToSend = speechTranscript.trim();
            const shouldSend = shouldSubmitSpeechTranscript && transcriptToSend.length > 0 && isSessionActive;

            isRecording = false;
            speechRecognition = null;
            resetVoiceButton(false);

            if (!shouldSubmitSpeechTranscript) {
                return;
            }

            if (!transcriptToSend) {
                addMessage('System', 'No speech was captured. Please try again.', true);
                return;
            }

            if (!shouldSend) {
                shouldSubmitSpeechTranscript = false;
                return;
            }

            elements.messageInput.value = transcriptToSend;
            shouldSubmitSpeechTranscript = false;
            await sendMessage();
        };

        speechRecognition.start();
        isRecording = true;
        setVoiceButtonRecordingState();
        updateStatus('Listening...', 'warning');
        return true;
    }

    async function startRecording() {
        try {
            const startedBrowserSpeech = await startBrowserSpeechRecognition();
            if (startedBrowserSpeech) {
                return;
            }
        } catch (speechError) {
            console.warn('[SPEECH] Browser speech recognition unavailable, falling back to audio upload:', speechError);
        }
        await startMediaRecorderCapture(false);
    }

    function stopRecording() {
        if (speechRecognition && isRecording) {
            clearSpeechSilenceTimer();
            updateStatus('Processing speech...', 'warning');
            speechRecognition.stop();
            return;
        }

        if (mediaRecorder && isRecording) {
            mediaRecorder.stop();
            isRecording = false;
            resetVoiceButton(true);
            updateStatus('Processing audio...', 'warning');
        }
    }

    async function sendAudio(audioBlob) {
        console.log('[AUDIO] ===== SENDING AUDIO TO WHISPER FOR TRANSCRIPTION =====');
        if (!isSessionActive || !sessionData) {
            addMessage('System', 'Session not active. Please start a session first.', true);
            resetVoiceButton(false);
            return;
        }

        if (!audioBlob || audioBlob.size === 0) {
            console.error('[AUDIO] Audio blob is empty or invalid');
            addMessage('System', 'No audio data to send. Please try recording again.', true);
            resetVoiceButton(false);
            return;
        }

        if (audioBlob.size < 1024) {
            console.error('[AUDIO] Audio blob too small:', audioBlob.size, 'bytes');
            addMessage('System', 'Audio recording is too short. Please record at least 1 second of audio.', true);
            resetVoiceButton(false);
            return;
        }

        if (audioBlob.size > 25 * 1024 * 1024) {
            console.error('[AUDIO] Audio blob too large:', audioBlob.size, 'bytes');
            addMessage('System', 'Audio recording is too large. Maximum size is 25MB.', true);
            resetVoiceButton(false);
            return;
        }

        try {
            showLoading('Processing audio with ElevenLabs...');
            updateStatus('Sending audio for transcription...', 'warning');
            
            let fileExtension = 'webm';
            if (audioBlob.type.includes('ogg')) {
                fileExtension = 'ogg';
            } else if (audioBlob.type.includes('mp4') || audioBlob.type.includes('mpeg')) {
                fileExtension = 'mp4';
            } else if (audioBlob.type.includes('wav')) {
                fileExtension = 'wav';
            }
            
            const fileName = `recording.${fileExtension}`;
            console.log('[AUDIO] Preparing to send audio:', {
                size: audioBlob.size,
                type: audioBlob.type,
                fileName: fileName
            });
            
            const formData = new FormData();
            formData.append('audio', audioBlob, fileName);
            formData.append('conversationId', sessionData.sessionId);
            
            if (streamingToken) {
                formData.append('streamingToken', streamingToken);
                console.log('[AUDIO] Including streamingToken (length:', streamingToken.length, ')');
            } else {
                console.warn('[AUDIO] WARNING: streamingToken is missing!');
            }
            const useClaude = document.getElementById('useClaudeToggle')?.checked === true;
            formData.append('useClaude', useClaude ? 'true' : 'false');

            console.log('[AUDIO] FormData contents:');
            for (const [key, value] of formData.entries()) {
                if (value instanceof File || value instanceof Blob) {
                    console.log(`  ${key}: [Blob/File] size=${value.size}, type=${value.type}`);
                } else {
                    console.log(`  ${key}: ${value}`);
                }
            }

            console.log('[API] Calling POST', `${API_BASE}/audio`, {
                conversationId: sessionData.sessionId,
                hasStreamingToken: !!streamingToken,
                audioSize: audioBlob.size,
                audioType: audioBlob.type
            });
            
            const response = await fetch(`${API_BASE}/audio`, {
                method: 'POST',
                body: formData
            });

            console.log('[API] /audio response status:', response.status, response.statusText);

            if (!response.ok) {
                let errorMessage = `HTTP ${response.status}`;
                let errorDetails = null;
                
                try {
                    const errorData = await response.json();
                    errorMessage = errorData.error || errorData.message || errorMessage;
                    errorDetails = errorData;
                    console.error('[API] /audio error response:', errorDetails);
                } catch (e) {
                    try {
                        const errorText = await response.text();
                        errorMessage = errorText || errorMessage;
                        console.error('[API] /audio error text:', errorText);
                    } catch (e2) {
                        console.error('[API] /audio - could not parse error response');
                    }
                }
                
                throw new Error(errorMessage);
            }

            const data = await response.json();
            console.log('[API] /audio success:', {
                hasUserTranscript: !!data.userTranscript,
                hasAvatarTranscript: !!data.avatarTranscript,
                sourceCount: data.sources?.length || 0
            });

            if (data.userTranscript) {
                addMessage('User', data.userTranscript);
            }

            if (data.avatarTranscript) {
                addMessage('Avatar', data.avatarTranscript);
            }

            if (data.sources) {
                updateSources(data.sources, data.isFallback);
            }

            hideLoading();
            updateStatus('Connected', 'success');

        } catch (error) {
            console.error('[AUDIO] Error sending audio:', error);
            console.error('[AUDIO] Error details:', {
                name: error.name,
                message: error.message,
                stack: error.stack
            });
            
            addMessage('System', `Error: ${error.message}`, true);
            hideLoading();
            updateStatus('Error', 'danger');
        } finally {
            resetVoiceButton(false);
        }
    }

    function toggleRecording() {
        console.log('[RECORD] Toggling voice recording (ElevenLabs)...');
        if (!isRecording) {
            startRecording();
        } else {
            stopRecording();
        }
    }

    elements.startButton.addEventListener('click', startSession);
    elements.stopButton.addEventListener('click', stopSessionHandler);
    elements.sendButton.addEventListener('click', sendMessage);
    elements.messageInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey && isSessionActive) {
            e.preventDefault();
            sendMessage();
        }
    });

    if (elements.chatToggleBtn) {
        elements.chatToggleBtn.addEventListener('click', toggleChatDrawer);
    }
    if (elements.closeChatBtn) {
        elements.closeChatBtn.addEventListener('click', closeChatDrawer);
    }
    if (elements.endCallBtn) {
        elements.endCallBtn.addEventListener('click', stopSessionHandler);
    }
    if (elements.muteBtn) {
        elements.muteBtn.addEventListener('click', toggleRecording);
    }

    window.addEventListener('beforeunload', async () => {
        stopKeepalive();
        if (sessionData) {
            await stopSession(sessionData.sessionId);
        }
        if (liveKitRoom) {
            try {
                liveKitRoom.disconnect();
            } catch (e) {
                console.error('Error disconnecting on unload:', e);
            }
        }
    });
})();
</script>
}
