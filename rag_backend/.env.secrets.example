# Copy this file to .env.secrets in this same folder (rag_backend/).
#   cp .env.secrets.example .env.secrets
# Then edit .env.secrets and paste your real key. .env.secrets is gitignored and is never committed.
#
# Used by rag_backend/app/main.py via load_dotenv(".env.secrets") for Claude (Anthropic) only.
# The .NET app does not read this file; ERSimulatorApp/appsettings.json does not store the Anthropic key.

ANTHROPIC_API_KEY=
