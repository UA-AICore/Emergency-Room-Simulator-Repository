# Use local Ollama (recommended for ER Simulator). Set to 1 to use a remote OpenAI-compatible LLM instead.
USE_REMOTE_LLM=0

# Local Ollama (when USE_REMOTE_LLM=0)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2
# Seconds to wait for Ollama response (gemma2 can be slow; default 180)
OLLAMA_TIMEOUT=180

# Remote LLM (when USE_REMOTE_LLM=1)
# OPENAI_BASE_URL=https://your-llm-server/v1
# OPENAI_API_KEY=YOUR_API_KEY_HERE
# OPENAI_MODEL=your-model

# Claude (Anthropic) — put the key in rag_backend/.env.secrets (untracked, in .gitignore)
# Create that file with:  ANTHROPIC_API_KEY=your-key
# Optional: ANTHROPIC_MODEL=claude-opus-4-6

# Embeddings + Vector DB (ChromaDB path is set in app/main.py)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# FastAPI app port (must match .NET RAG:BaseUrl port)
APP_PORT=8010

# ---------- Knowledge Base API (optional; replaces Chroma PDF retrieval) ----------
# Default: chromadb (local PDF chunks + embeddings). Set to knowledge_api to call an HTTP search endpoint instead.
# RAG_CONTEXT_SOURCE=chromadb
# KNOWLEDGE_API_SEARCH_URL=https://your-provider.com/v1/knowledge/search
# KNOWLEDGE_API_KEY=your-secret
# KNOWLEDGE_API_AUTH_STYLE=bearer
# KNOWLEDGE_API_METHOD=POST
# KNOWLEDGE_API_QUERY_KEY=query
# KNOWLEDGE_API_TOP_K_KEY=top_k
# KNOWLEDGE_API_EXTRA_BODY={"namespace":"trauma"}
# KNOWLEDGE_API_METHOD=GET
# KNOWLEDGE_API_GET_QUERY_PARAM=q
# KNOWLEDGE_API_GET_LIMIT_PARAM=limit
# KNOWLEDGE_API_AUTH_STYLE=query
# KNOWLEDGE_API_QUERY_AUTH_PARAM=api_key
# Skip PDF ingest in start-app.sh when using KB only:
# SKIP_PDF_INGEST=1
