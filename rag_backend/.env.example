# Use local Ollama (recommended for ER Simulator). Set to 1 to use a remote OpenAI-compatible LLM instead.
USE_REMOTE_LLM=0

# Local Ollama (when USE_REMOTE_LLM=0)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2

# Remote LLM (when USE_REMOTE_LLM=1)
# OPENAI_BASE_URL=https://your-llm-server/v1
# OPENAI_API_KEY=YOUR_API_KEY_HERE
# OPENAI_MODEL=your-model

# Embeddings + Vector DB (ChromaDB path is set in app/main.py)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# FastAPI app port (must match .NET RAG:BaseUrl port)
APP_PORT=8010
