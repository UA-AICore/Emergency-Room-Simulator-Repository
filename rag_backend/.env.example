# Use a local Ollama-compatible server (recommended for ER Simulator).
# Set to 1 to use a remote OpenAI-compatible LLM instead.
USE_REMOTE_LLM=0

# ---------- "Local" answer-engine backend ----------
# The RAG backend talks to an Ollama-compatible HTTP API (POST /api/chat).
# Two drop-in options for the "Local" radio button in the avatar UI:
#
#   (A) Fine-tuned MedGemma via rag_backend/finetuning/serve.py (default)
#       Start it with:
#         source rag_backend/.venv/bin/activate
#         uvicorn rag_backend.finetuning.serve:app --host 127.0.0.1 --port 11435
#       OLLAMA_URL=http://127.0.0.1:11435
#       OLLAMA_MODEL=medgemma-ft
#
#   (B) Plain Ollama on 11434 (whatever you've `ollama pull`-ed)
#       OLLAMA_URL=http://127.0.0.1:11434
#       OLLAMA_MODEL=alibayram/medgemma:27b     # or gemma2:latest, etc.
OLLAMA_URL=http://127.0.0.1:11435
OLLAMA_MODEL=medgemma-ft
# Seconds to wait for a response. 4B fine-tuned on GPU is fast.
OLLAMA_TIMEOUT=300

# Remote LLM (when USE_REMOTE_LLM=1)
# OPENAI_BASE_URL=https://your-llm-server/v1
# OPENAI_API_KEY=YOUR_API_KEY_HERE
# OPENAI_MODEL=your-model

# Claude (Anthropic) — keys live ONLY in rag_backend/.env.secrets (you create it; it is gitignored).
# There is no .env.secrets in the repo. Copy the template:
#   cp .env.secrets.example .env.secrets
# Then set ANTHROPIC_API_KEY=... inside .env.secrets (or export it in the shell / systemd for codira-rag).
# Optional in .env.secrets: ANTHROPIC_MODEL=claude-opus-4-6

# Embeddings + Vector DB (ChromaDB path is set in app/main.py)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# FastAPI app port (must match .NET RAG:BaseUrl port)
APP_PORT=8010

# ---------- Knowledge Base API (optional; replaces Chroma PDF retrieval) ----------
# Default: chromadb (local PDF chunks + embeddings). Set to knowledge_api to call an HTTP search endpoint instead.
# RAG_CONTEXT_SOURCE=chromadb
# KNOWLEDGE_API_SEARCH_URL=https://your-provider.com/v1/knowledge/search
# KNOWLEDGE_API_KEY=your-secret
# KNOWLEDGE_API_AUTH_STYLE=bearer
# KNOWLEDGE_API_METHOD=POST
# KNOWLEDGE_API_QUERY_KEY=query
# KNOWLEDGE_API_TOP_K_KEY=top_k
# KNOWLEDGE_API_EXTRA_BODY={"namespace":"trauma"}
# KNOWLEDGE_API_METHOD=GET
# KNOWLEDGE_API_GET_QUERY_PARAM=q
# KNOWLEDGE_API_GET_LIMIT_PARAM=limit
# KNOWLEDGE_API_AUTH_STYLE=query
# KNOWLEDGE_API_QUERY_AUTH_PARAM=api_key
# Skip PDF ingest in start-app.sh when using KB only:
# SKIP_PDF_INGEST=1
